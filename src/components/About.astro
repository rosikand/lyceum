---
import { site } from "../data/site";
import { withBase } from "../lib/withBase";
import SocialLinks from "./SocialLinks.astro";
---

<section id="about">
  <div class="container">
    <div class="about-grid">
      <div class="profile-col">
        <img
          class="avatar"
          src={withBase(site.avatar)}
          alt={site.name}
          width="200"
          height="200"
        />
        <SocialLinks />
      </div>
      <div class="bio">
        <h1 class="bio-name">{site.name}</h1>
        {/* TODO: Replace this bio with your own. Inline links and <strong> are fine. */}
        <p>
          Hello! I'm a placeholder bio. I am a <strong>researcher</strong> at
          <a href="https://example.com" target="_blank" rel="noopener">
            Your Institution</a
          >, where I work on a topic you find genuinely interesting. Write a
          sentence or two about what you do and what motivates it.
        </p>
        <p>
          You can mention advisors, collaborators, or funding here — for example,
          I am grateful to be supported by the
          <a href="https://example.com" target="_blank" rel="noopener">
            <strong>Example Fellowship</strong></a
          >. Keep it short and human.
        </p>
      </div>
    </div>
  </div>
</section>
