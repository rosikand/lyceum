---
import { site } from "../data/site";
import { withBase } from "../lib/withBase";

// Normalize the current path (trailingSlash is "ignore" in astro.config).
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const home = withBase("/").replace(/\/+$/, "") || "/";

function isActive(href: string): boolean {
  const target = withBase(href).replace(/\/+$/, "") || "/";
  if (target === home) return path === home;
  return path === target || path.startsWith(target + "/");
}
---

<nav class="site-nav" aria-label="Primary">
  <div class="nav-inner">
    <a class="nav-brand" href={withBase("/")}>{site.name}</a>
    <div class="nav-links">
      {
        site.nav.map((item) => (
          <a href={withBase(item.href)} class:list={["nav-link", { active: isActive(item.href) }]}>
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>
